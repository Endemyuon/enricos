# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
# .env files are now tracked for production deployment
# .env.local is still ignored for local development

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database
# SQLite database files are now tracked for backup
# /data/*.sqlite
# /data/*.sqlite-shm
# /data/*.sqlite-wal
