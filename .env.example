# Resend Email API
RESEND_API_KEY=your_resend_api_key

# Email sender address (must be verified in Resend dashboard)
RESEND_FROM_EMAIL=noreply@enricos.shop

# Application URL (used for verification and password reset links)
# For production:
NEXT_PUBLIC_APP_URL=https://enricos.shop

# Database (SQLite - Local)
# SQLite database files stored in /data directory
# For production, consider migrating to PostgreSQL
DATABASE_URL=sqlite:///data/accounts.sqlite

