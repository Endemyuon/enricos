# Resend Email API
RESEND_API_KEY=your_resend_api_key

# Email sender address
# For development: use onboarding@resend.dev (Resend test email)
# For production: verify a custom domain in Resend and use noreply@yourdomain.com
RESEND_FROM_EMAIL=onboarding@resend.dev

# Application URL (used for verification and password reset links)
# For production:
NEXT_PUBLIC_APP_URL=https://enricos.shop

# Database (SQLite - Unified)
# Single SQLite database file containing all tables
DATABASE_URL=sqlite:///data/enricos.sqlite

